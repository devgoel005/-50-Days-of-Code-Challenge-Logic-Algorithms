class node{
    public:
    int data;
    node* next;

    node(int data1){
       data=data1;
       next=NULL;
    }
};

void insert(node*&head, node*&tail, int val){
    node * newnode= new node(val);

    if(head==NULL){
        head=newnode;
        tail=newnode;
        return;
    }
    tail->next=newnode;
    tail=newnode;
}

