#include<bits/stdc++.h>
using namespace std;
class Node{
    public:
    int data;
    Node* next;

    public:
    Node(int data1){
        data = data1;
        next = NULL;
    }

    public:
    Node(int data1, Node* next1){
        data = data1;
        next = next1;
    }
};

//Enter and take the value in the LL in O(1)TC
void insertval(Node*&head, Node*&tail,int val){
    Node* newnode= new Node(val);

    if(head==NULL){
        head=newnode;
        tail=newnode;
        return;
    }
    (*tail).next=newnode;
    tail=newnode;

}

//Reverse the LL
Node* reverse(Node*&head){
    Node*temp = head;
    Node* pre= NULL;
    if(head==NULL){
        return(head);
    }
    while(temp!=NULL){
        Node* front= temp->next;
        temp->next= pre;
        pre=temp;
        temp=front;
    }
    head=pre;
    return pre;
}

void deletenode(Node*&head){

    if(head==NULL){
        return; 
    }

    head=reverse(head);

    Node* curr=head;
    int max=curr->data;

    while(curr->next!=NULL){
    if(curr->next->data<max){
       Node* del=curr->next;
       curr->next=curr->next->next;
       delete del;

    }
    else{
    max=curr->next->data;
    curr=curr->next;
    }
    }
    
    head=reverse(head);
   

    

}

