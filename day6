#include<bits/stdc++.h>
using namespace std;

class node{
    public:
    int data;
    node* next;

    node(int data1){
        data = data1;
        next = NULL;          // fixed: initialize next
    }

    node(int data1, node* next1){
        data = data1;
        next = next1;
    }
};

node* middle(node* head){
    node* slow = head;
    node* fast = head->next;
    while(fast != NULL && fast->next != NULL){
        slow = slow->next;
        fast = fast->next->next;
    }
    return slow;
}

node* merge(node*& head1, node*& head2){
    node* dummy = new node(-1);
    node* temp = dummy;
    while(head1 != NULL && head2 != NULL){
        if(head1->data <= head2->data){
            temp->next = head1;
            head1 = head1->next;
        } else {
            temp->next = head2;
            head2 = head2->next;
        }
        temp = temp->next;
    }
    // fixed: attach whichever list still has leftover nodes
    temp->next = (head1 != NULL) ? head1 : head2;

    return dummy->next;
}

void insertval(node*& head, node*& tail, int val){
    node* newnode = new node(val);
    if(head == NULL){
        head = newnode;
        tail = newnode;
        return;
    }
    tail->next = newnode;
    tail = newnode;
}

void print(node* head){
    node* temp = head;
    while(temp != NULL){
        cout << temp->data << " ";
        temp = temp->next;
    }
    cout << " ";
}

int main(){
    node* head1 = NULL;
    node* tail1 = NULL;
    node* head2 = NULL;
    node* tail2 = NULL;

    int n;
    //cout << "Enter size of the Linked List1 ";
    cin >> n;
    if(0 < n && n < 1000000000){
        for(int i = 0; i < n; i++){
            int val;
            cin >> val;
            insertval(head1, tail1, val);
        }
    }
    cout << endl;
    //print(head1);
    cout << endl;

    int m;
    //cout << "Enter size of the Linked List2 ";
    cin >> m;
    if(0 < m && m < 1000000000){
        for(int i = 0; i < m; i++){        // fixed: m, not n
            int val;
            cin >> val;
            insertval(head2, tail2, val);
        }
    }
    cout << endl;
   //print(head2);
    cout << endl;

    node* final = merge(head1, head2);
    print(final);                          // fixed: actually print the merged result

